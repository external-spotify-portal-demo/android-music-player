{
  "name": "android-music-player",
  "version": "2.4.1",
  "description": "Spotify's Android music player service with AI recommendation engine",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "seed": "node scripts/seed-data.js",
    "test": "jest",
    "test:recommendations": "jest --testPathPattern=recommendations"
  },
  "ai_recommendation_engine": {
    "enabled": true,
    "model": "spotify-rec-v2",
    "version": "1.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ai-recommendation-engine": "^1.0.0",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
